# Must match `docker-compose.yml` db service (default: postgres / postgres / tfd_tracker).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tfd_tracker?schema=public"
# Required for OAuth cookies and CSRF. Generate: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"
DISCORD_CLIENT_ID="your-discord-client-id"
DISCORD_CLIENT_SECRET="your-discord-client-secret"
# Discord Developer Portal → OAuth2 → Redirects: add exactly:
#   http://localhost:3000/api/auth/callback/discord

# Tier list mod tools (optional): comma-separated Discord user IDs (snowflakes) who may adjust synthetic vote overlays and delete TierVote rows. Leave empty to disable. Find your ID with Discord developer mode (right-click profile → Copy User ID).
TIER_LIST_MOD_DISCORD_IDS=""

# Nexon Open API (optional) — Player Lookup tab /tfd/v1/* — register at https://openapi.nexon.com/game/tfd/
# Never commit real keys. Rotate if exposed.
NEXON_OPEN_API_KEY=""
